# --- App ---
NODE_ENV=development
APP_BASE_URL=http://localhost:5173
PORT=3000
SESSION_SECRET=

# --- Auth ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Comma-separated emails granted the `admin` role on signup/login.
ADMIN_EMAILS=yourrealtoradamd@gmail.com

# --- LLM ---
ANTHROPIC_API_KEY=
LLM_MODEL_EXTRACT=claude-haiku-4-5-20251001
LLM_MODEL_REASON=claude-sonnet-4-6
LLM_MODEL_DEEP=claude-opus-4-8

# --- Data provider (see BuildSpec §7.1) ---
# Leave blank to auto-select: uses ATTOM/RentCast if their key is set below,
# otherwise falls back to the built-in `mock` provider (synthetic demo comps) so
# the app works with only an ANTHROPIC_API_KEY. Set explicitly to force one.
DATA_PROVIDER=                # mock | attom | rentcast | bright_mls (blank = auto)
ATTOM_API_KEY=
HOUSECANARY_API_KEY=
HOUSECANARY_API_SECRET=
RENTCAST_API_KEY=

# --- Bright MLS RESO Web API (Adam's core-market feed) ---
BRIGHT_MLS_BASE_URL=
BRIGHT_MLS_TOKEN=
BRIGHT_MLS_ENABLED=false

# --- Geocoder ---
GEOCODER=census               # provider | census | google
GOOGLE_GEOCODE_KEY=

# --- Database ---
DATABASE_URL=file:./arv-engine.sqlite   # sqlite file path OR postgres url

# --- Billing (Phase C, optional) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# --- Engine knobs (defaults; all overridable per-request) ---
COMP_RADIUS_MILES=1.0
COMP_RADIUS_MAX_MILES=5.0
COMP_MONTHS_BACK=6
COMP_TARGET_COUNT=6
COMP_CANDIDATE_COUNT=50
OUTLIER_THRESHOLD_PCT=0.20
GLA_ADJ_PER_SQFT=55
MAO_PERCENT=0.70
QUICK_SALE_DISCOUNT=0.0675     # 6.75% below market value
TEST_MARKET_PREMIUM=0.055      # 5.5% above market value
ROUND_TO_ENDING=9900           # all list prices end in X9,900
CACHE_TTL_HOURS=72
